## API 使用示例

```python
from toolcall_resilience import (
    ToolExecutor,
    ToolRegistry,
    ToolSchema,
    ParameterSchema,
    ParameterType,
    RetryConfig,
    BackoffStrategy,
)
from toolcall_resilience.tools import register_builtin_tools

# 1. 注册工具
register_builtin_tools()

# 或者自定义注册
registry = ToolRegistry()

def my_tool(a: int, b: str = "default") -> dict:
    return {"result": a * 2, "message": b}

registry.register(
    name="my_tool",
    func=my_tool,
    schema=ToolSchema(
        name="my_tool",
        description="My custom tool",
        parameters=[
            ParameterSchema(
                name="a",
                type_=ParameterType.INTEGER,
                required=True,
                minimum=0,
            ),
            ParameterSchema(
                name="b",
                type_=ParameterType.STRING,
                required=False,
                default="default",
            ),
        ],
    ),
)

# 2. 创建执行器
executor = ToolExecutor(tool_registry=registry)

# 3. 配置重试
retry_config = RetryConfig(
    max_attempts=3,
    initial_delay_ms=100,
    backoff_strategy=BackoffStrategy.EXPONENTIAL,
    timeout_seconds=5.0,
)

# 4. 执行调用
response = executor.execute(
    request={"tool_name": "my_tool", "parameters": {"a": 10}},
    retry_config=retry_config,
    auto_fix_parameters=True,
    validate_response=True,
)

# 5. 检查结果
if response.success:
    print(f"结果: {response.final_result}")
else:
    print(f"失败: {response.final_error}")
    print(f"尝试次数: {response.attempt_count}")
    for attempt in response.attempts:
        if attempt.error:
            print(f"  第{attempt.attempt_number}次尝试错误: {attempt.error['message']}")
```

